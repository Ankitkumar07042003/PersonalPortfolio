# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/ankit_portfolio
CLIENT_ORIGIN=http://localhost:3000
# ─── MongoDB ──────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/ankit_portfolio
# Atlas (production):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ankit_portfolio?retryWrites=true&w=majority

# ─── CORS ─────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000

# ─── Email (optional — for forwarding contact msgs) ──
# Uses Nodemailer to forward contact form submissions to your inbox.
# For Gmail, generate an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFY_EMAIL=your_notify_email@gmail.com
